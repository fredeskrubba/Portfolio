---
import InfoBox from '../components/InfoBox.astro';
import { experience } from '../assets/data/experience.json';
import CarouselSection from '../components/CarouselSection.astro';
import { stack } from '../assets/data/tech-stack.json';
import { projects } from '../assets/data/projects.json';
import en from '../assets/translations/en.json';
import da from '../assets/translations/da.json';

const lang = Astro.url.pathname.startsWith('/da') ? 'da' : 'en';
const t = lang === 'da' ? da : en;
---


<section class="section-container">
    <InfoBox class="reveal"/> 
    <section class="info-section">
      <div class="intro vertical-carousel-item reveal">
        <h1>{t['intro-title']}</h1>
        <article class="intro-box">
          <p>{t['intro-paragraph']}</p>
        </article>
      </div>
      <div class="experience vertical-carousel-item reveal">
        
          <CarouselSection data={experience} />
        
      </div>
      <div class="stack vertical-carousel-item reveal">
        
          <CarouselSection data={stack} />
        
      </div>
      <div class="projects vertical-carousel-item reveal">
        
          <CarouselSection data={projects}/>
        
      </div>
    </section>
    <div class="dots">
      <div class="dot active" data-index="0" title="intro"/>
      <div class="dot" data-index="1" title="experience"/>
      <div class="dot" data-index="2" title="tech stack"/>
      <div class="dot" data-index="3" title="projects"/>
    </div>
</section>


<style>
  section {
    padding: 0 80px;
    display: grid;
    grid-template-columns: 1fr 3fr 0.1fr;
    background-color: var(--background);
    color: var(--text);
    height: 100%;
    overflow-y: hidden;
    align-items: flex-start;
  }

  .section-container {
    height: 100dvh;
    margin-bottom: 20px;
    order: 999;
  }

 .info-section {
  position: relative;
  height: 100%;
  width: 100%;
  overflow: hidden; 

  display: flex;
  justify-content: center;
  align-items: center;

  perspective: 1000px; 
}

.vertical-carousel-item {
  position: absolute;
  top: 40%;
  left: 50%;
  width: 100%;
  max-width: 1200px;
  

  transform: translate(-50%, -50%) scale(0.8);
  /* opacity: 0.5; */
  filter: blur(2px);

  transition: all 0.4s ease;

}



  .intro h1 {
    font-size: 90px;
    font-weight: 600;
    margin: 0;
    color: var(--main-color);
    text-align: center;
  }

  .intro-box {
    border: 1px solid var(--main-color);
    padding: 30px 40px;
    background-color: var(--theme-bg);
    color: var(--main-color);
    min-height: 200px;
  }

  .intro-box p {
    font-size: 20px;
  }
  .stack {
  z-index: 3;
  transform: translateY(0) scale(1);
}


.experience {
  z-index: 2;
  transform: translateY(-160px) scale(0.85) rotateX(15deg);
  /* opacity: 0.7; */
  filter: blur(1px);
}


.projects {
  z-index: 2;
  transform: translateY(160px) scale(0.85) rotateX(-15deg);
  /* opacity: 0.7; */
  filter: blur(1px);
}

@media (min-width: 1024px) {
  .vertical-carousel-item.hidden {
    transform: translate(-50%, -50%) scale(0.7);
    opacity: 0;
    pointer-events: none;
  }
  
  .vertical-carousel-item.active {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
  filter: none;
  z-index: 3;
  border-radius: 15px;
  background-color: color-mix(in srgb, var(--theme-bg), transparent 40%);
  padding: 10px;
}


.vertical-carousel-item.prev {
  transform: translate(-50%, calc(-50% - 180px)) scale(0.85);
  opacity: 0.7;
  z-index: 2;
  pointer-events: none;
}


.vertical-carousel-item.next {
  transform: translate(-50%, calc(-50% + 180px)) scale(0.85);
  opacity: 0.7;
  z-index: 2;
  pointer-events: none;
}

  .dots {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 10px;
    padding-right: 20px;
    align-self: center;
  }
  
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--theme-bg);
    border: 1px solid var(--main-color);
    opacity: 0.5;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  
  .dot.active {
    opacity: 1;
    background-color: var(--main-color);
  }
  
  .dot:hover {
    opacity: 0.8;
  }
  
}
</style>


<style is:global> 
  @media (max-width: 1024px) {
    .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: 0.6s ease;
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
  }
</style>
 
<style>

@media (max-width: 1024px) {

      h1 {
      text-shadow:
      -1px -1px 0 var(--theme-bg),
      0   -1px 0 var(--theme-bg),
      1px -1px 0 var(--theme-bg),
      1px  0   0 var(--theme-bg),
      1px  1px 0 var(--theme-bg),
      0    1px 0 var(--theme-bg),
      -1px  1px 0 var(--theme-bg),
      -1px  0   0 var(--theme-bg);
    }
    
  .vertical-carousel-item.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: 0.6s ease;
  }

  .vertical-carousel-item.reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .intro h1 {
    font-size: 60px;
    text-align: center;
    font-weight: 600;
    margin: 0;
    color: var(--main-color);
    text-align: start;
  }

  .infobox {
    
  }
  section {
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
    align-items: center;
  }

  .section-container {
    height: 100%;
    margin-bottom: 20px;
  }

  .info-section {
    display: block;
    position: static;
    height: auto;
    width: 100%;
    overflow: visible;
    perspective: none;
  }

  .vertical-carousel-item {
    position: static;
    top: auto;
    left: auto;
    width: 100%;
    max-width: none;
    transform: none;
    opacity: 1;
    filter: none;
    transition: none;
    margin-bottom: 20px;
  }

  .vertical-carousel-item.active,
  .vertical-carousel-item.prev,
  .vertical-carousel-item.next,
  .vertical-carousel-item.hidden {
    transform: none;
    opacity: 1;
    filter: none;
    z-index: auto;
    background-color: transparent;
    padding: 0;
  }

  .dots {
    display: none;
  }
}
</style>

<style>
  @media (max-width: 768px) {
    .intro h1 {
      font-size: 60px;
      margin-bottom: 10px;
    }

    .intro-box {
      padding: 10px 20px;
    }

  }

</style>


<script>
  const isDesktop = window.matchMedia("(min-width: 1024px)");
  const scrollContainer = document.querySelector(".section-container");

  if (isDesktop.matches) {
    const items = document.querySelectorAll(".vertical-carousel-item");
    const dots = document.querySelectorAll(".dot");

    let current = 0;
    let isScrolling = false;

    function updateClasses() {
      items.forEach((item, index) => {
        item.classList.remove("active", "prev", "next", "hidden");

        if (index === current) {
          item.classList.add("active");
        } else if (index === current - 1) {
          item.classList.add("prev");
        } else if (index === current + 1) {
          item.classList.add("next");
        } else {
          item.classList.add("hidden");
        }
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle("active", index === current);
      });
    }

    function handleScroll(e) {
      if (isScrolling) return;

      isScrolling = true;

      if (e.deltaY > 0) {
        current = Math.min(current + 1, items.length - 1);
      } else {
        current = Math.max(current - 1, 0);
      }

      updateClasses();

      setTimeout(() => {
        isScrolling = false;
      }, 400);
    }

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        current = index;
        updateClasses();
      });
    });

    window.addEventListener("wheel", handleScroll, { passive: true });

    updateClasses();
  }

  isDesktop.addEventListener("change", e => {
    location.reload(); 
  });

  if (!isDesktop.matches) {
  document.addEventListener("DOMContentLoaded", () => {
    const elements = document.querySelectorAll(".reveal");

    const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add("active");
    }
  });
}, {
  threshold: 0.3, // must be 30% visible
  rootMargin: "0px 0px -35% 0px", // delay trigger
  root: scrollContainer || null // use scroll container if available;
});

    elements.forEach(el => observer.observe(el));
  });
}
</script>