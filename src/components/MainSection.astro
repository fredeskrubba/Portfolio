---
import InfoBox from '../components/InfoBox.astro';
import { experience } from '../assets/data/experience.json';
import CarouselSection from '../components/CarouselSection.astro';
import { stack } from '../assets/data/tech-stack.json';
import { projects } from '../assets/data/projects.json';
---


<section class="section-container">
    <InfoBox /> 
    <section class="info-section">
      <div class="intro vertical-carousel-item">
        <h1>John Doe</h1>
        <article class="intro-box">
          <p>Hello, I'm John Doe, a passionate developer.</p>
        </article>
      </div>
      <div class="experience vertical-carousel-item ">
        
          <CarouselSection data={experience} />
        
      </div>
      <div class="stack vertical-carousel-item">
        
          <CarouselSection data={stack} />
        
      </div>
      <div class="projects vertical-carousel-item">
        
          <CarouselSection data={projects}/>
        
      </div>
    </section>
    <div class="dots">
      <div class="dot active" data-index="0" title="intro"/>
      <div class="dot" data-index="1" title="experience"/>
      <div class="dot" data-index="2" title="tech stack"/>
      <div class="dot" data-index="3" title="projects"/>
    </div>
</section>


<style>
  section {
    padding: 0 80px;
    display: grid;
    grid-template-columns: 1fr 3fr 0.1fr;
    background-color: var(--background);
    color: var(--text);
    height: 100%;
    overflow-y: hidden;
  }

  .section-container {
    height: 100dvh;
    margin-bottom: 20px;
  }

 .info-section {
  position: relative;
  height: 100%;
  width: 100%;
  overflow: hidden; 

  display: flex;
  justify-content: center;
  align-items: center;

  perspective: 1000px; 
}

.vertical-carousel-item {
  position: absolute;
  top: 40%;
  left: 50%;

  width: 70%;
  max-width: 800px;


  transform: translate(-50%, -50%) scale(0.8);
  opacity: 0.5;
  filter: blur(2px);

  transition: all 0.4s ease;

}


.vertical-carousel-item.active {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
  filter: none;
  z-index: 3;
  border-radius: 15px;
  background-color: color-mix(in srgb, var(--theme-bg), transparent 40%);
  padding: 10px;
}


.vertical-carousel-item.prev {
  transform: translate(-50%, calc(-50% - 180px)) scale(0.85);
  opacity: 0.7;
  z-index: 2;
}


.vertical-carousel-item.next {
  transform: translate(-50%, calc(-50% + 180px)) scale(0.85);
  opacity: 0.7;
  z-index: 2;
}


  .intro h1 {
    font-size: 100px;
    font-weight: 600;
    margin: 0;
    color: var(--main-color);
  }

  .intro-box {
    border: 1px solid var(--main-color);
    padding: 30px 40px;
    background-color: var(--theme-bg);
    color: var(--main-color);
  }

  .stack {
  z-index: 3;
  transform: translateY(0) scale(1);
}


.experience {
  z-index: 2;
  transform: translateY(-160px) scale(0.85) rotateX(15deg);
  opacity: 0.7;
  filter: blur(1px);
}


.projects {
  z-index: 2;
  transform: translateY(160px) scale(0.85) rotateX(-15deg);
  opacity: 0.7;
  filter: blur(1px);
}

.vertical-carousel-item.hidden {
  transform: translate(-50%, -50%) scale(0.7);
  opacity: 0;
  pointer-events: none;
}

.dots {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 10px;
  padding-right: 20px;
}

.dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: var(--theme-bg);
  border: 1px solid var(--main-color);
  opacity: 0.5;
  cursor: pointer;
  transition: opacity 0.3s ease;
}

.dot.active {
  opacity: 1;
  background-color: var(--main-color);
}

.dot:hover {
  opacity: 0.8;
}
</style>

<script>
  const items = document.querySelectorAll(".vertical-carousel-item");
  const dots = document.querySelectorAll(".dot");

  let current = 0;
  let isScrolling = false;

  function updateClasses() {
    items.forEach((item, index) => {
      item.classList.remove("active", "prev", "next", "hidden");

      if (index === current) {
        item.classList.add("active");
      } 
      else if (index === current - 1) {
        item.classList.add("prev");
      } 
      else if (index === current + 1) {
        item.classList.add("next");
      } 
      else {
        item.classList.add("hidden"); // 👈 important
      }
    });
    updateDots();
  }

  function updateDots() {
    dots.forEach((dot, index) => {
      dot.classList.toggle("active", index === current);
    });
  }

  function handleScroll(e) {
    if (isScrolling) return;

    isScrolling = true;

    if (e.deltaY > 0) {
      current = Math.min(current + 1, items.length - 1);
    } else {
      current = Math.max(current - 1, 0);
    }

    updateClasses();

    setTimeout(() => {
      isScrolling = false;
    }, 400);
  }

  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => {
      current = index;
      updateClasses();
    });
  });

  window.addEventListener("wheel", handleScroll, { passive: true });

  updateClasses();
</script>