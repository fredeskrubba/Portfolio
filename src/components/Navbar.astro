---
import Lightmode from "../assets/icons/Lightmode.svg";
import EnglishLanguage from "../assets/icons/English-language.svg";
---

<nav class="navbar">
  <ul class="nav-links">
    <li class="nav-icons"><img src={Lightmode.src} alt="Light mode" /></li>
    <li class="nav-icons"><img src={EnglishLanguage.src} alt="English language" /></li>
  </ul>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    width: 100%;
    border-bottom: 1px solid var(--darkmode);
    padding: 5px 15px 15px 15px;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    margin-left: auto;
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: center;
  }

  .nav-icons {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  
  .nav-links img {
    width: 3rem;
    height: 3rem;
    display: block;
  }



</style>