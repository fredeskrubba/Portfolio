---
import "../styles/variables.css";
import Navbar from "./Navbar.astro";
---


<header>
     <Navbar/>
</header>

<style>
    header {
        width: 100%;
        padding: 20px 80px;
        background-repeat: repeat, no-repeat;
        background-size: auto, 100% 100%;
        color: var(--darkmode);
        min-height: 100px;
    }

    header > div {
        margin-top: 1.5rem;
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    h1 {
        font-size: 3rem;
        margin: 0;
        font-weight: 400;
    }
</style>

<style>
    /* Mobile devices */
    @media (max-width: 768px) {
        header {
            padding: 10px 20px;
        }
    }

    
</style>