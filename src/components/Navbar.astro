---
import DanishLanguage from "../assets/icons/Danish-language.svg";
import { EnglishLanguage } from "../assets/data";
import { Lightmode, Darkmode } from "../assets/data";

const lang = Astro.url.pathname.startsWith('/da') ? 'da' : 'en';

---

<nav class="navbar">
  <ul class="nav-links">
    <li class="nav-icons theme-toggle" aria-label="Toggle color theme">
      <Lightmode class="theme-toggle-svg theme-icon theme-icon-light" />
      <Darkmode class="theme-toggle-svg theme-icon theme-icon-dark" />
    </li>
    <li class="lang-icons">
      { lang === 'da' &&  <EnglishLanguage id="toggle-english" />}
      { lang === 'en' && <DanishLanguage id="toggle-danish" /> }
    </li>
  </ul>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    width: 100%;
    border-bottom: 1px solid var(--theme-border);
    padding: 5px 15px 15px 15px;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    margin-left: auto;
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: center;
  }

  .nav-icons {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }


  .theme-toggle-svg {
    width: 3rem;
    height: 3rem;
    display: block;
  }

  .theme-icon {
    display: none;
  }

  .theme-icon.active {
    display: block;
  }

  .theme-toggle-svg circle {
    fill: var(--theme-bg);
  }

  .theme-toggle-svg path {
    fill: var(--theme-bg);
  }

  .nav-links > li:first-child {
    cursor: pointer;
  }

  .lang-icons svg {
    fill: var(--theme-bg);
    height: 3rem;
    width: 3rem;
  }

</style>

<style>
  /* Mobile devices */
  @media (max-width: 768px) {
    /* Add mobile-specific styles here */
  }

  /* Medium devices (tablets) */
  @media (max-width: 1024px) {
    
  }
</style>

<script >
 
  function updateThemeIcon() {
    const root = document.documentElement;
    const isLight = root.getAttribute("data-theme") === "light";
    const lightIcon = document.querySelector(".theme-icon-light");
    const darkIcon = document.querySelector(".theme-icon-dark");


    if (!lightIcon || !darkIcon) return;

    if (isLight) {
      lightIcon.classList.remove("active");
      darkIcon.classList.add("active");
    } else {
      lightIcon.classList.add("active");
      darkIcon.classList.remove("active");
    }
  }


  function bindThemeToggle() {
    const ul = document.querySelector(".nav-links");
    const firstLi = ul?.querySelector("li:first-child");
    if (!firstLi) return;

    
    firstLi.addEventListener("click", () => {
      const root = document.documentElement;
      const isLight = root.getAttribute("data-theme") === "light";
      if (isLight) {
        root.removeAttribute("data-theme");
        localStorage.setItem("theme", "dark");
      } else {
        root.setAttribute("data-theme", "light");
        localStorage.setItem("theme", "light");
      }
      updateThemeIcon();
    });

    updateThemeIcon();
  }

 
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      bindThemeToggle();
    });
  } else {
    bindThemeToggle();
  } 

  document.addEventListener('DOMContentLoaded', () => {
    const daBtn = document.getElementById('toggle-danish');
    const enBtn = document.getElementById('toggle-english');

    daBtn && daBtn.addEventListener('click', () => {
      let newPath = "/da"; 

      window.location.pathname = newPath;
    });

    enBtn && enBtn.addEventListener('click', () => {
      let newPath = "/en"; 

      window.location.pathname = newPath;
    });

  });
  
</script>