---
import "../styles/variables.css";
import Navbar from "./Navbar.astro";
---


<header>
     <Navbar/>

</header>

<style>
    header {
        width: 100%;
        
        padding: 45px 80px;
        background: linear-gradient(180deg, var(--main-color) 3%, var(--theme-bg) 94%);
        color: var(--darkmode);
        min-height: 500px;
    }

    header > div {
        margin-top: 1.5rem;
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    h1 {
        font-size: 3rem;
        margin: 0;
        font-weight: 400;
    }
</style>