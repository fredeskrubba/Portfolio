---
import EnglishLanguage from "../assets/icons/English-language.svg";
---

<nav class="navbar">
  <ul class="nav-links">
    <li class="nav-icons" aria-label="Toggle color theme">
      <svg
        class="theme-toggle-svg"
        width="64"
        height="64"
        viewBox="0 0 64 64"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <circle cx="32" cy="32" r="32" />
        <path
          d="M24.926 39.076C22.9753 37.1253 22 34.7667 22 32C22 29.2333 22.9753 26.8753 24.926 24.926C26.8767 22.9767 29.2347 22.0013 32 22C34.7653 21.9987 37.124 22.974 39.076 24.926C41.028 26.878 42.0027 29.236 42 32C41.9973 34.764 41.022 37.1227 39.074 39.076C37.126 41.0293 34.768 42.004 32 42C29.232 41.996 26.874 41.0207 24.926 39.074M18 34H10V30H18V34ZM54 34H46V30H54V34ZM30 18V10H34V18H30ZM30 54V46H34V54H30ZM20.8 23.5L15.75 18.65L18.6 15.7L23.4 20.7L20.8 23.5ZM45.4 48.3L40.55 43.25L43.2 40.5L48.25 45.35L45.4 48.3ZM40.5 20.8L45.35 15.75L48.3 18.6L43.3 23.4L40.5 20.8ZM15.7 45.4L20.75 40.55L23.5 43.2L18.65 48.25L15.7 45.4Z"
        />
      </svg>
    </li>
    <li class="nav-icons"><img src={EnglishLanguage.src} alt="English language" /></li>
  </ul>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    width: 100%;
    border-bottom: 1px solid var(--theme-border);
    padding: 5px 15px 15px 15px;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    margin-left: auto;
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: center;
  }

  .nav-icons {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  
  .nav-links img {
    width: 3rem;
    height: 3rem;
    display: block;
  }

  .theme-toggle-svg {
    width: 3rem;
    height: 3rem;
    display: block;
  }

  .theme-toggle-svg circle {
    fill: var(--theme-toggle-disc);
  }

  .theme-toggle-svg path {
    fill: var(--theme-toggle-icon);
  }

  .nav-links > li:first-child {
    cursor: pointer;
  }
</style>

<script>
  function bindThemeToggle() {
    const ul = document.querySelector(".nav-links");
    const firstLi = ul?.querySelector("li:first-child");
    if (!firstLi) return;

    firstLi.addEventListener("click", () => {
      const root = document.documentElement;
      const isLight = root.getAttribute("data-theme") === "light";
      if (isLight) {
        root.removeAttribute("data-theme");
        localStorage.setItem("theme", "dark");
      } else {
        root.setAttribute("data-theme", "light");
        localStorage.setItem("theme", "light");
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindThemeToggle);
  } else {
    bindThemeToggle();
  }
</script>