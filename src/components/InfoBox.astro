---
import GithubIcon from '../assets/icons/github-icon.svg';
import LinkedinIcon from '../assets/icons/linkedin-icon.svg';
import MailIcon from '../assets/icons/mail-icon.svg';

import en from '../assets/translations/en.json';
import da from '../assets/translations/da.json';
import ProfilePic from '../assets/profile-pic.jpg';

const lang = Astro.url.pathname.startsWith('/da') ? 'da' : 'en';
const { class: className = "" } = Astro.props;
const t = lang === 'da' ? da : en;
---

<article class={`infobox ${className}`}>
    <img src={ProfilePic.src} alt="Profile Picture" class="profile-pic">
    <button type="button" class="cv-button" id="cv-download" >{t['resume-button']}</button>

    <div class="link-container">
        <a href="https://github.com/fredeskrubba" target="_blank" rel="noopener noreferrer"><GithubIcon /></a>
        <a href="https://www.linkedin.com/in/frederik-skrubbeltrang-698b4a1a3/" target="_blank" rel="noopener noreferrer"><LinkedinIcon /></a>
        <a href="mailto:frederikskrubbeltrang@proton.me" target="_blank" rel="noopener noreferrer"><MailIcon /></a>
    </div>
</article>

<script>
    const cvButton = document.getElementById('cv-download');
    
    function downloadCV() {
        const link = document.createElement('a');
        link.href = '/CV.pdf';
        link.download = 'Frederik_Skrubbeltrang_CV.pdf';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
    cvButton.addEventListener('click', downloadCV);
</script>

<style>
    .infobox {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        border: 1px solid var(--main-color);
        padding: 30px 40px;
        border-radius: 15px;
        background-color: color-mix(in srgb, var(--theme-bg), transparent 80%);
        height: auto;
    }

    .profile-pic {
        width: 100%;
        height: 400px;
        object-fit: cover;
        border-radius: 15px;
    }

    .cv-button {
        width: 100%;
        padding: 20px 0px;
        background-color: var(--main-color);
        border: none;
        color: var(--theme-text);
        border-radius: 2px;
        font-size: 30px;
        font-weight: 600;
    }

    .cv-button:hover, .link-container a:hover {
        background-color: var(--hover-light);
        cursor: pointer;
    }

    .link-container {
        display: flex;
        width: 100%;
        align-items: center;
        justify-content: space-between;
        height: 90px;
    }

    .link-container a {
        display: block;
        background-color: var(--main-color);
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 2px;
        padding: 22px;
    }

    .link-container a svg {
       fill: var(--theme-bg);
    }

</style>

<style>

    
     /* Medium devices (tablets) */
     @media (max-width: 1024px) {
      
        .infobox {
            width: 100%;
            margin: 0 50px;
            padding: 20px 30px;
            justify-self: flex-start;
            order: 2;
        }
        .profile-pic {
            height: 450px;
            width: 200px;
        }

        .cv-button {
            font-size: 30px;
            padding: 25px 0px;
        }
       
        .link-container {
            height: 60px;
            justify-content: space-between;
            gap: 10px;
        }
        
        .link-container a {
            width: 250px;
            height: 80px;
        }
        .link-container a svg{
            height: 45px;
            width: 45px;
        }

     }

     @media (max-width: 768px) {
        .link-container {
            height: 60px;
            justify-content: space-between;
            gap: 10px;
        }
        
       
        .link-container a svg{
            height: 35px;
            width: 35px;
        }

        .profile-pic {
            height: 300px;
        }
     }
     

</style>