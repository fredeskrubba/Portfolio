---
import EnglishLanguage from "../assets/icons/English-language.svg";
import DanishLanguage from "../assets/icons/Danish-language.svg";
import { Lightmode, Darkmode } from "../assets/data";
---

<nav class="navbar">
  <ul class="nav-links">
    <li class="nav-icons theme-toggle" aria-label="Toggle color theme">
      <Lightmode class="theme-toggle-svg theme-icon theme-icon-light" />
      <Darkmode class="theme-toggle-svg theme-icon theme-icon-dark" />
    </li>
    <li>
      <DanishLanguage class="lang-toggle danish-icon"/>
      <EnglishLanguage class="lang-toggle english-icon"/>
    </li>
  </ul>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    width: 100%;
    border-bottom: 1px solid var(--theme-border);
    padding: 5px 15px 15px 15px;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    margin-left: auto;
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: center;
  }

  .nav-icons {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }


  .theme-toggle-svg, .lang-toggle {
    width: 3rem;
    height: 3rem;
    display: block;
  }

  .theme-icon {
    display: none;
  }

  .theme-icon.active {
    display: block;
  }

  .lang-toggle {
    display: none;
  }

  .lang-toggle.active {
    display: block;
  }

  .theme-toggle-svg circle {
    fill: var(--theme-bg);
  }

  .theme-toggle-svg path {
    fill: var(--theme-bg);
  }

  .nav-links > li:first-child {
    cursor: pointer;
  }

  .lang-toggle {
    fill: var(--theme-bg);

  }
  .lang-toggle:hover {
    cursor: pointer;
  }
</style>

<script >

  import { translations } from "../assets/data/translations.js";

  const englishIcon = document.querySelector(".english-icon");
  const danishIcon = document.querySelector(".danish-icon");
  let currentLang = localStorage.getItem("lang") || "en";


  function updateThemeIcon() {
    const root = document.documentElement;
    const isLight = root.getAttribute("data-theme") === "light";
    const lightIcon = document.querySelector(".theme-icon-light");
    const darkIcon = document.querySelector(".theme-icon-dark");


    if (!lightIcon || !darkIcon) return;

    if (isLight) {
      lightIcon.classList.remove("active");
      darkIcon.classList.add("active");
    } else {
      lightIcon.classList.add("active");
      darkIcon.classList.remove("active");
    }
  }

  function applyTranslations(lang) {
    document.querySelectorAll("[data-i18n]").forEach(el => {
      const key = el.getAttribute("data-i18n");
      el.textContent = translations[lang][key];
    });

    updateLanguageIcon();
  }

  function updateLanguageIcon() {
    
    
    if (currentLang === "da") {
      danishIcon.classList.remove("active");
      englishIcon.classList.add("active");
    } else {
      danishIcon.classList.add("active");
      englishIcon.classList.remove("active");
    }
  }

  function bindThemeToggle() {
    const ul = document.querySelector(".nav-links");
    const firstLi = ul?.querySelector("li:first-child");
    if (!firstLi) return;

    
    firstLi.addEventListener("click", () => {
      const root = document.documentElement;
      const isLight = root.getAttribute("data-theme") === "light";
      if (isLight) {
        root.removeAttribute("data-theme");
        localStorage.setItem("theme", "dark");
      } else {
        root.setAttribute("data-theme", "light");
        localStorage.setItem("theme", "light");
      }
      updateThemeIcon();
    });

    updateThemeIcon();
  }

 
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      bindThemeToggle();
    });
  } else {
    bindThemeToggle();
  }

  applyTranslations(currentLang);

  englishIcon.addEventListener("click", () => {
    currentLang = "en";
    localStorage.setItem("lang", currentLang);
    applyTranslations(currentLang);
  });

  danishIcon.addEventListener("click", () => {
    currentLang = "da";
    localStorage.setItem("lang", currentLang);
    applyTranslations(currentLang);
  });
  
</script>