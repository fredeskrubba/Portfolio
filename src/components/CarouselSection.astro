---
interface Experience {
  title: string;
  position: { en: string; da: string };
  duration: { en: string; da: string };
  description: { en: string; da: string };
  bullets?: { en: string; da: string }[];
  stack: { name: string; icon: string; }[];
}

interface StackItem {
 page1: { name: string; icon: string; }[];
}

interface Project {
  title: string;
  description: { en: string; da: string };
  image: string;
  url: string;
  stack: { name: string; icon: string; }[];
}

interface Props {
  data: Project[] | Experience[] | StackItem[];
  lang?: string;
}

import { ExperienceIcon, StackIcon, ProjectsIcon, Arrow, RedirectArrow } from '../assets/data';
import * as Icons from '../assets/data';
import en from '../assets/translations/en.json';
import da from '../assets/translations/da.json';

const lang = Astro.url.pathname.startsWith('/da') ? 'da' : 'en';
const t = lang === 'da' ? da : en;
const { data } = Astro.props;


const isExperience = (item: any): item is Experience => 'position' in item;
const isProject = (item: any): item is Project => 'url' in item;
const isStack = (item: any): item is StackItem => !('position' in item) && !('url' in item);

let sectionTitle = "";
const firstItem = data[0];

if (isExperience(firstItem)) {
  sectionTitle = t['experience-title'];
} else if (isProject(firstItem)) {
  sectionTitle = t['projects-title'];
} else if (isStack(firstItem)) {
  sectionTitle = t['stack-title'];
}

const Icon = isExperience(firstItem) ? ExperienceIcon : isProject(firstItem) ? ProjectsIcon : StackIcon;
---

<section class="carousel-section" data-count={data.length}>
  <article class="info-header">
    <div class="flex">
      <Icon />
      <h2>{sectionTitle}</h2>
    </div>
    {
      data.length > 1 && (
      <div class="carousel-controls">
        <button class="nav-btn prev" aria-label="Previous">
          <Arrow />
        </button>
  
        <div class="dots-wrapper">
          {data.map((_, i) => (
            <span class={`slider-dot ${i === 0 ? 'active' : ''}`} data-index={i}></span>
          ))}
        </div>
  
        <button class="nav-btn next" aria-label="Next">
          <Arrow style="transform: rotate(180deg);" />
        </button>
      </div>
      <div class="carousel-controls-mobile">
        <button class="nav-btn-mobile prev" aria-label="Previous">
          <Arrow />
        </button>

        <button class="nav-btn-mobile next" aria-label="Next">
          <Arrow style="transform: rotate(180deg);" />
        </button>
      </div>
      )
    }
  </article>
  <div class="carousel-window" id="carousel-window">
    {data.map((item) => (
      <div class="carousel-item">
        {/* EXPERIENCE */}
        {isExperience(item) && (
          <div class="experience-card card">
            <div class="experience-header">
              <h3>{item.title}</h3>
              <h4>{item.duration[lang]}</h4>
            </div>
            <h5>{item.position[lang]}</h5>
            <p>{item.description[lang]}</p>
            {
              item.bullets && (
                <ul class="bullets">
                  {item.bullets.map(b => <li>{b[lang]}</li>)}
                </ul>
              )
            }
            <div class="mini-stack">
              {item.stack.map(s => {
                const IconComp = Icons[s.icon];
                return IconComp ? <span data-tooltip={s.name}><IconComp class="mini-stack-icon"/></span> : null;
              })}
            </div>
          </div>
        )}

        {/* STACK ITEM */}
        
          
            
            {isStack(item) && (
              <div class="stack-page card">
                {item.page1.map(s => {
                  const IconComp = Icons[s.icon];
                  return IconComp ? <span data-tooltip={s.name}><IconComp class="tech-stack-icon"/></span> : null;
                })}
              </div>
            )}  
        

        {/* PROJECT */}
        {isProject(item) && (
          <a href={item.url} target="_blank" rel="noopener noreferrer">
            <div class="project-card card">
              <div style={`background-image: url(${item.image});`} class="project-image">
                <img src={item.image} alt={item.title} />
              </div>
              <div class="project-info">
                <div>
                  <div class="project-header">
                    <h3>{item.title}</h3>
                    <RedirectArrow class="redirect-arrow"/>
                  </div>
                  <p>{item.description[lang]}</p>
                </div>
                 <div class="project-stack">
                  {item.stack.map(s => {
                    const IconComp = Icons[s.icon];
                    return IconComp ? <span data-tooltip={s.name}><IconComp class="mini-stack-icon"/></span> : null;
                  })}
                </div>
              </div>
            </div>
          </a>
        )}

      </div>
    ))}
  </div>

  
</section>

<style>
    .info-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
    padding-bottom: 5px;
    border-bottom: 1px solid var(--main-color);
    margin-bottom: 30px;
  }
  
  .flex {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .info-header h2 {
    font-size: 40px;
    font-weight: 600;
    margin: 0;
    color: var(--main-color);
  }
  
  .carousel-container {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .carousel-window {
    display: grid;
    border-radius: 8px;
    position: relative;
  }

  .carousel-item {
    grid-column: 1;
    grid-row: 1;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    box-sizing:initial;
    pointer-events: none;
  }

  .carousel-item.active {
    opacity: 1;
    pointer-events: auto;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 1rem;
  }

  .carousel-controls-mobile {
    display: none;
  }

  .nav-btn {
    background: var(--theme-bg);
    border: 1px solid var(--main-color);
    color: var(--theme-bg);
    padding: 5px 15px;
    cursor: pointer;
    width: 45px;    
    height: 45px;
    border-radius: 50%;
  }

  .nav-btn:hover {
    background: var(--theme-bg);
    color: white;
  }

  .dots-wrapper {
    display: flex;
    gap: 8px;
  }

  .slider-dot {
    width: 12px;
    height: 12px;
    background: #ccc;
    border-radius: 50%;
    transition: 0.3s;
    border: 1px solid var(--main-color);
    background: var(--theme-bg);
  }

  .slider-dot:hover {
    cursor: pointer;
  }

  .slider-dot.active {
    background: var(--main-color);
    transform: scale(1.3);
  }

  .card {
    min-height: 400px;

  }
  .experience-card {
    background-color: var(--theme-bg);
    color: var(--main-color);
    padding: 10px;
    border: 1px solid var(--main-color);
    border-radius: 5px;
    flex-direction: column;
    display: flex;
  }

  .bullets {
    margin: 10px 0;
  }

  .bullets li {
    font-size: 15px;
  }
  .experience-card h3 {
    margin: 0;
    font-size: 34px;
  }

  .experience-card h4, .experience-card h5 {
    font-size: 18px;
    font-weight: 300;
    font-style: italic;
  }

  .experience-card h5 {
    margin: 5px 0;
  }

  .experience-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--main-color);
    margin-bottom: 5px;
  }

  ul {
    margin: 0;
    padding-left: 20px;
  }

  .mini-stack {
    display: flex;
    gap: 10px;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .stack-page {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    background-color: var(--theme-bg);
    padding: 10px;
    border: 1px solid var(--main-color);
    border-radius: 5px;
    align-content: flex-start;
  }

  .project-card {
    background-color: var(--theme-bg);
    color: var(--main-color);
    padding: 10px;
    border: 1px solid var(--main-color);
    border-radius: 5px;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 10px;
    font-size: 18px;
    transition: all 0.2s ease-in-out;
    height: 100%;
  }

  .project-card img {
    border-radius: 15px;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;

  }
  .project-info {
    padding: 10px;
    display: flex;
    flex-direction: column;
  }
  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .project-header h3 {
    margin: 0;
    font-size: 34px;
  }

  .project-stack {
    display: flex;
    gap: 10px;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .project-image {
    position: relative;
    border-radius: 5px;
    overflow: hidden;

    background-image: var(--bg-image);
    background-size: cover;
    background-position: center;
  }

  
  .project-image::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--bg-image);
    background-size: cover;
    background-position: center;
    filter: blur(10px);
    transform: scale(1.1); 
    z-index: 0;
  }

  .project-image > * {
    position: relative;
    z-index: 1;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  svg {
    fill: var(--theme-bg);
  }

  .tech-stack-icon:hover, .mini-stack-icon:hover {
    transform: translatey(-5px);
  }

  .tech-stack-icon {
    width: 60px;
    height: 60px;
    transition: transform 0.2s ease;
  }

  .mini-stack-icon {
    width: 40px;
    height: 40px;
    transition: transform 0.2s ease;
  }

  span[data-tooltip] {
    position: relative;
  }

  span[data-tooltip]:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--theme-bg);
    color: var(--main-color);
    padding: 5px 10px;
    border-radius: 4px;
    border: 1px solid var(--main-color);
    white-space: nowrap;
    z-index: 10;
    font-size: 12px;
    font-weight: 500;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  span[data-tooltip]:not(:hover)::after {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 1024px) {

    .info-header h2 {
      font-size: 30px;
      text-shadow:
      -1px -1px 0 var(--theme-bg),
      0   -1px 0 var(--theme-bg),
      1px -1px 0 var(--theme-bg),
      1px  0   0 var(--theme-bg),
      1px  1px 0 var(--theme-bg),
      0    1px 0 var(--theme-bg),
      -1px  1px 0 var(--theme-bg),
      -1px  0   0 var(--theme-bg);
    }

  .info-header svg {
    width: 35px;
    height: 35px;
    stroke: var(--theme-bg);
    stroke-width: 1.5px;
  }

  }
</style>
  
<style>

@media (max-width: 768px) {
  
  .info-header h2 {
    font-size: 30px;
    text-shadow:
    -1px -1px 0 var(--theme-bg),
     0   -1px 0 var(--theme-bg),
     1px -1px 0 var(--theme-bg),
     1px  0   0 var(--theme-bg),
     1px  1px 0 var(--theme-bg),
     0    1px 0 var(--theme-bg),
    -1px  1px 0 var(--theme-bg),
    -1px  0   0 var(--theme-bg);
  }

  .info-header svg {
    width: 35px;
    height: 35px;
    stroke: var(--theme-bg);
    stroke-width: 1.5px;
  }

  .experience-card h3 {
    margin: 0;
    font-size: 18px;
  }

  .experience-card h4, .experience-card h5 {
    font-size: 12px;
    font-weight: 300;
    font-style: italic;
  }

  .carousel-controls-mobile {
    display: flex;
    gap: 10px;
  }

  .nav-btn-mobile {
    background: var(--theme-bg);
    border: 1px solid var(--main-color);
    color: var(--theme-bg);
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    width: 25px;    
    height: 25px;
    border-radius: 50%;
  }
  .carousel-controls {
    display: none;
  }
  ul {
    margin: 0;
    font-size: 10px;
  }
  .mini-stack {
    display: flex;
    gap: 10px;
    margin-top: auto;
    flex-wrap: wrap;
    width: 100%;
  }

  .stack-page {
    justify-content: space-between;
  }

  .project-card {
    grid-template-columns: 1fr;
  }

  .redirect-arrow {
    display: none;
  }

  .project-stack {
    margin-top: 10px;
  }
  
}

</style>

<script>
  document.querySelectorAll('.carousel-section').forEach(section => {
  const prevBtn = section.querySelector('.nav-btn.prev');
  const nextBtn = section.querySelector('.nav-btn.next');
  const prevBtnMobile = section.querySelector('.nav-btn-mobile.prev');
  const nextBtnMobile = section.querySelector('.nav-btn-mobile.next');
  const dots = section.querySelectorAll('.slider-dot');
  const items = section.querySelectorAll('.carousel-item');

  let currentIndex = 0;
  const totalItems = items.length;

  function showSlide(index) {
    if (index < 0) currentIndex = totalItems - 1;
    else if (index >= totalItems) currentIndex = 0;
    else currentIndex = index;

    items.forEach((item, i) => {
      item.classList.toggle('active', i === currentIndex);
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentIndex);
    });
  }

  prevBtn?.addEventListener('click', () => showSlide(currentIndex - 1));
  nextBtn?.addEventListener('click', () => showSlide(currentIndex + 1));
  prevBtnMobile?.addEventListener('click', () => showSlide(currentIndex - 1));
  nextBtnMobile?.addEventListener('click', () => showSlide(currentIndex + 1));

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => showSlide(i));
  });

  if (items.length > 0) {
    showSlide(0);
  }
});
</script>