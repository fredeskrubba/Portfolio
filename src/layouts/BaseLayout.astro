---
import "../styles/variables.css";
import Header from "../components/Header.astro";

const { Title = "Frederik Skrubbeltrang" } = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "light"){
            document.documentElement.setAttribute("data-theme", "light");
          }
          else {
            document.documentElement.removeAttribute("data-theme");
          }
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://fonts.bunny.net/css?family=ibm-plex-sans:400,500,600,700" />
    <title>{Title}</title>
  </head>
  <body>
    <main>
       <Header/>
        <slot />
    </main>
  </body>
  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    :global(*) {
      box-sizing: border-box;
    }

    :global(html, body) {
      margin: 0;
      padding: 0;
      height: 100dvh;
    }
    :global(body) {
      margin: 0;
      overflow-y: auto;
      font-family: "IBM Plex Sans", Arial, Helvetica, sans-serif;
      background-color: var(--theme-bg);
      background-image:
            var(--page-pattern),
            linear-gradient(180deg, var(--main-color) 3%, var(--theme-bg) 54%);
      background-repeat: repeat;
      color: var(--theme-text);
      opacity: 0;
      animation: fadeIn 1.5s ease-in-out forwards;
    }

    :global(h1, h2, h3, h4, h5, h6, p) {
      margin: 0;
      padding: 0;

    }
    h1 {
      font-size: 2rem;
      margin: 0;
    }

    main {
      display: flex;
      flex-direction: column;
      height: 100dvh;
    }
  </style>
</html>
