---
interface Experience {
  title: string;
  position: string;
  duration: string;
  description: string;
  stack: { name: string; icon: string; }[];
}

interface StackItem {
  name: string;
  icon: string;
}

interface Project {
  title: string;
  description: string;
  image: string;
  url: string;
  stack: StackItem[];
}

interface Props {
  data: Project[] | Experience[] | StackItem[];
}

import ExperienceIcon from '../assets/icons/experience-icon.svg';
import StackIcon from '../assets/icons/stack-icon.svg';
import ProjectsIcon from '../assets/icons/projects-icon.svg';
import Arrow from '../assets/icons/Arrow.svg';
const { data } = Astro.props;

const isExperience = (item: any): item is Experience => 'position' in item;
const isProject = (item: any): item is Project => 'url' in item;
const isStack = (item: any): item is StackItem => !('position' in item) && !('url' in item);

let sectionTitle = "";
const firstItem = data[0];

if (isExperience(firstItem)) {
  sectionTitle = "My Experience";
} else if (isProject(firstItem)) {
  sectionTitle = "My Projects";
} else if (isStack(firstItem)) {
  sectionTitle = "My Tech Stack";
}

const Icon = isExperience(firstItem) ? ExperienceIcon : isProject(firstItem) ? ProjectsIcon : StackIcon;
---

<section class="carousel-section" data-count={data.length}>
  <article class="info-header">
    <div class="flex">
      <Icon />
      <h2>{sectionTitle}</h2>
    </div>
    {
      data.length > 1 && (
      <div class="carousel-controls">
        <button class="nav-btn prev" id="prev-btn" aria-label="Previous">
          <Arrow />
        </button>
  
        <div class="dots-wrapper">
          {data.map((_, i) => (
            <span class={`dot ${i === 0 ? 'active' : ''}`} data-index={i}></span>
          ))}
        </div>
  
        <button class="nav-btn next" id="next-btn" aria-label="Next">
          <Arrow style="transform: rotate(180deg);" />
        </button>
      </div>
        
      )
    }
  </article>
  <div class="carousel-window" id="carousel-window">
    {data.map((item) => (
      <div class="carousel-item">
        {/* TYPE 1: EXPERIENCE */}
        {isExperience(item) && (
          <div class="experience-card">
            <div class="experience-header">
              <h3>{item.title}</h3>
              <h4>{item.duration}</h4>
            </div>
            <h5>{item.position}</h5>
            <p>{item.description}</p>
            <div class="mini-stack">
              {item.stack.map(s => <img src={s.icon} title={s.name} />)}
            </div>
          </div>
        )}

        {/* TYPE 2: PROJECT */}
        {isProject(item) && (
          <div class="project-card">
            <img src={item.image} alt={item.title} />
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a href={item.url}>View Project</a>
          </div>
        )}

        {/* TYPE 3: STACK ITEM */}
        {isStack(item) && (
          <div class="stack-card">
            <img src={item.icon} alt={item.name} />
            <span>{item.name}</span>
          </div>
        )}
      </div>
    ))}
  </div>

  
</section>

<style>
    .info-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
    padding-bottom: 5px;
    border-bottom: 1px solid var(--main-color);
    margin-bottom: 10px;
  }
  
  .flex {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .info-header h2 {
    font-size: 40px;
    font-weight: 600;
    margin: 0;
    color: var(--main-color);
  }

  .carousel-container {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .carousel-window {
    display: flex;
    overflow: hidden; 
    scroll-behavior: smooth;
    border-radius: 8px;
  }

  .carousel-item {
    flex: 0 0 100%; 
    box-sizing: border-box;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 1rem;
  }

  .nav-btn {
    background: var(--theme-bg);
    border: 1px solid var(--main-color);
    color: var(--theme-bg);
    padding: 5px 15px;
    cursor: pointer;
    width: 45px;    
    height: 45px;
    border-radius: 50%;
  }

  .nav-btn:hover {
    background: var(--theme-bg);
    color: white;
  }

  .dots-wrapper {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 12px;
    height: 12px;
    background: #ccc;
    border-radius: 50%;
    transition: 0.3s;
    border: 1px solid var(--main-color);
  }

  .dot.active {
    background: var(--theme-bg);
    transform: scale(1.3);
  }

  .experience-card {
    background-color: var(--theme-bg);
    color: var(--main-color);
    padding: 10px;
    border: 1px solid var(--main-color);
  }

  .experience-card h3 {
    margin: 0;
    font-size: 34px;
  }

  .experience-card h4 {
    font-size: 18px;
    font-weight: 300;
    font-style: italic;
  }
  .experience-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid var(--main-color);
  }

  .mini-stack {
    display: flex;
    gap: 10px;
    margin-top: 15px;
  }

  .mini-stack img {
    width: 50px;
    height: 50px;
  }
</style>

<script>
  // Find all carousels on the page
  const carousels = document.querySelectorAll('.carousel-container');

  carousels.forEach((container) => {
    const window = container.querySelector('#carousel-window');
    const prevBtn = container.querySelector('#prev-btn');
    const nextBtn = container.querySelector('#next-btn');
    const dots = container.querySelectorAll('.dot');
    const totalItems = parseInt(container.getAttribute('data-count'));
    
    let currentIndex = 0;

    const updateCarousel = (index) => {
      // Ensure index stays within bounds
      if (index < 0) index = totalItems - 1; // Loop to end
      if (index >= totalItems) index = 0;    // Loop to start
      
      currentIndex = index;

      // Scroll the window
      const offset = window.clientWidth * currentIndex;
      window.scrollTo({ left: offset, behavior: 'smooth' });

      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });
    };

    prevBtn.addEventListener('click', () => updateCarousel(currentIndex - 1));
    nextBtn.addEventListener('click', () => updateCarousel(currentIndex + 1));

    // Optional: Allow clicking dots directly
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => updateCarousel(i));
    });

    // Resize listener to keep things aligned if window size changes
    window.addEventListener('resize', () => updateCarousel(currentIndex));
  });
</script>